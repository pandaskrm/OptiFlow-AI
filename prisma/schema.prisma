generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Reception {
  id          Int      @id @default(autoincrement())
  number      String   @unique
  supplier    String
  carrier     String
  dock        String
  pallets     Int
  status      String
  scheduledAt String
  createdAt   DateTime @default(now())
}