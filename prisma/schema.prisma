generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/**
 * AUTHENTIFICATION ET ENTREPRISES
 */

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships         Membership[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  invitationsCreated  Invitation[]         @relation("InvitationCreator")
  auditLogs           AuditLog[]           @relation("AuditActor")
}

model Company {
  id         String   @id @default(cuid())
  name       String
  legalName  String?
  siret      String?
  email      String?
  phone      String?
  address    String?
  postalCode String?
  city       String?
  country    String   @default("France")
  logoUrl    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  invitations Invitation[]
  warehouses  Warehouse[]
  auditLogs   AuditLog[]

  receptions  Reception[]
  orders      Order[]
  shipments   Shipment[]
  inventories Inventory[]
  workforce   Workforce[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("OPERATOR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Invitation {
  id          String    @id @default(cuid())
  companyId   String
  email       String
  role        String    @default("OPERATOR")
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  invitedById String?
  createdAt   DateTime  @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
  @@index([expiresAt])
}

model Warehouse {
  id         String   @id @default(cuid())
  companyId  String
  name       String
  code       String
  address    String?
  postalCode String?
  city       String?
  country    String   @default("France")
  timezone   String   @default("Europe/Paris")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  docks   Dock[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Dock {
  id          String   @id @default(cuid())
  warehouseId String
  name        String
  code        String
  type        String   @default("MIXED")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([actorId])
  @@index([createdAt])
}

/**
 * DONNÉES LOGISTIQUES
 * companyId reste facultatif pendant la transition afin de ne pas casser
 * les API actuelles. Il deviendra obligatoire quand l’isolation multi-client
 * sera branchée dans les services.
 */

model Reception {
  id          Int       @id @default(autoincrement())
  number      String    @unique
  supplier    String
  carrier     String
  dock        String
  pallets     Int
  status      String
  scheduledAt String
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Order {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  customer      String
  carrier       String?
  priority      String    @default("Normale")
  status        String    @default("À préparer")
  totalLines    Int       @default(0)
  preparedLines Int       @default(0)
  scheduledAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Shipment {
  id          Int       @id @default(autoincrement())
  number      String    @unique
  orderNumber String?
  customer    String
  carrier     String
  dock        String?
  status      String    @default("À expédier")
  pallets     Int       @default(0)
  packages    Int       @default(0)
  scheduledAt DateTime?
  shippedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Inventory {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  designation String
  location    String?
  quantity    Int      @default(0)
  reserved    Int      @default(0)
  minimum     Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Workforce {
  id             Int      @id @default(autoincrement())
  employeeNumber String   @unique
  name           String
  team           String?
  zone           String?
  status         String   @default("Présent")
  workedMinutes  Int      @default(0)
  processedUnits Int      @default(0)
  workDate       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
}
